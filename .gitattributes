# Normalize text files
* text=auto

# Keep scripts and docs as text
*.py text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat generated media/model/archive/database files as binary when present
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.mp4 binary
*.wav binary
*.zip binary
*.7z binary
*.db binary
*.sqlite binary
*.safetensors binary
*.ckpt binary
*.pt binary
*.pth binary
*.onnx binary
*.bin binary
